FROM node:20-alpine

WORKDIR /app

COPY package*.json ./
RUN npm install

COPY . .

ARG VITE_API_URL
ARG VITE_BOOKING_SERVICE_URL
ARG VITE_INTERVIEWER_SERVICE_URL
ARG VITE_SUBMISSION_SERVICE_URL
ARG VITE_EVALUATION_SERVICE_URL
ARG VITE_MESSAGING_URL
ARG VITE_SIGNALING_URL
ARG VITE_PACKAGE_SERVICE_URL

ENV VITE_API_URL=$VITE_API_URL
ENV VITE_BOOKING_SERVICE_URL=$VITE_BOOKING_SERVICE_URL
ENV VITE_INTERVIEWER_SERVICE_URL=$VITE_INTERVIEWER_SERVICE_URL
ENV VITE_SUBMISSION_SERVICE_URL=$VITE_SUBMISSION_SERVICE_URL
ENV VITE_EVALUATION_SERVICE_URL=$VITE_EVALUATION_SERVICE_URL
ENV VITE_MESSAGING_URL=$VITE_MESSAGING_URL
ENV VITE_SIGNALING_URL=$VITE_SIGNALING_URL
ENV VITE_PACKAGE_SERVICE_URL=$VITE_PACKAGE_SERVICE_URL

RUN npm run build

EXPOSE 3000

CMD ["npx", "vite", "preview", "--host", "0.0.0.0", "--port", "3000"]
